{
  "name": "@vitabletech/gbp-sdk",
  "version": "1.0.0",
  "description": "Enterprise-grade Google Business Profile (GBP) SDK for Node.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:api": "typedoc",
    "docs:dev": "npm run docs:api && vitepress dev docs",
    "docs:build": "npm run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs": "npm run docs:build",
    "prepare": "husky"
  },
  "keywords": [
    "google",
    "google-business-profile",
    "gbp",
    "sdk",
    "api",
    "node",
    "typescript",
    "react",
    "nextjs",
    "oauth2",
    "google-my-business",
    "gmb"
  ],
  "author": "Mayank Singh kushwah (https://vitabletech.in)",
  "homepage": "https://gbp.vitabletech.in",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitabletech/gbp-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/vitabletech/gbp-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@eslint/eslintrc": "^2.1.4",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "msw": "^2.0.11",
    "prettier": "^3.9.0",
    "tsup": "^8.0.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.3.3",
    "vitepress": "^1.6.4",
    "vitest": "^1.0.4"
  }
}
